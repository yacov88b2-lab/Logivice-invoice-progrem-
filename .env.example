# Source of Truth - Use these exact variable names in your .env file
# Last updated: 2026-05-05

# Tableau Configuration
TABLEAU_TOKEN_NAME=wind
TABLEAU_TOKEN_VALUE=your_token_here
TABLEAU_SITE=logivice
TABLEAU_BASE_URL=https://logivice.tableau.com

# Mock data fallback
# Development can use mock data when Tableau is unavailable.
# In production, leave this false so invoice generation fails instead of using fake data.
ALLOW_MOCK_DATA=false

# Storage (Railway persistent volume - set automatically by Railway)
RAILWAY_VOLUME_MOUNT_PATH=/app/data

# Server
NODE_ENV=production
PORT=3001

# Frontend
VITE_API_URL=http://localhost:3001/api

# Initial admin account
# Used only when the database creates the default admin user for the first time.
ADMIN_PASSWORD=replace_with_a_secure_password
