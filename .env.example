# Source of Truth - Use these exact variable names in your .env file
# Last updated: 2026-05-05

# Tableau Configuration
TABLEAU_TOKEN_NAME=wind
TABLEAU_TOKEN_VALUE=your_token_here
TABLEAU_SITE=logivice
TABLEAU_BASE_URL=https://logivice.tableau.com

# Mock data fallback
# Development can use mock data when Tableau is unavailable.
# In production, leave this false so invoice generation fails instead of using fake data.
ALLOW_MOCK_DATA=false

# Storage (Railway persistent volume - set automatically by Railway)
RAILWAY_VOLUME_MOUNT_PATH=/app/data

# Server
NODE_ENV=production
PORT=3001

# Frontend
VITE_API_URL=http://localhost:3001/api

# Initial super admin account
# SUPER_ADMIN_FORCE_PASSWORD_RESET=true resets the existing seeded super-admin
# password to SUPER_ADMIN_PASSWORD on startup. Use it only for recovery/rotation.
SUPER_ADMIN_EMAIL=Jacob.b@unilog.company
SUPER_ADMIN_PASSWORD=replace_with_a_secure_password
SUPER_ADMIN_FORCE_PASSWORD_RESET=false
# Legacy fallback still supported for older deployments: ADMIN_PASSWORD
JWT_SECRET=replace_with_a_long_random_secret

# Anthropic API key — required for the Rule Assistant (AI step suggester)
# Get yours at https://console.anthropic.com/settings/api-keys
# If not set, the Rule Assistant returns 503 and is disabled silently.
ANTHROPIC_API_KEY=replace_with_anthropic_api_key
