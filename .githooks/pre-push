#!/bin/sh
set -eu

# Pre-push hook: print summary + block common accidental files.
# Note: git hooks run in a POSIX shell (Git Bash) on Windows.

REMOTE_NAME="${1:-}"
REMOTE_URL="${2:-}"

echo "======================================"
echo " Pre-push checks"
echo "======================================"
echo "Remote: ${REMOTE_NAME} ${REMOTE_URL}"
echo

echo "Changes summary (staged/committed differences not shown; this is your working tree vs HEAD):"
echo "--------------------------------------"
git status --short || true
echo

echo "Diffstat (working tree vs HEAD):"
echo "--------------------------------------"
git diff --stat || true
echo

# Block obvious generated/runtime files
BLOCK_PATTERNS='(
  (^|/)node_modules/|
  (^|/)dist/|
  \\.sqlite(-wal|-shm)?$|
  \\.db(-wal|-shm)?$|
  \\.log$|
  (^|/)data/.*\.(sqlite|sqlite3|db)$
)'

# List files that are staged for commit (preferred). If nothing staged, fall back to all changed files.
STAGED_FILES=$(git diff --cached --name-only || true)
if [ -z "$STAGED_FILES" ]; then
  CHECK_FILES=$(git diff --name-only || true)
else
  CHECK_FILES="$STAGED_FILES"
fi

# Find blocked files
BLOCKED=$(printf "%s\n" "$CHECK_FILES" | grep -E "$BLOCK_PATTERNS" || true)

if [ -n "$BLOCKED" ]; then
  echo "ERROR: blocked files detected. Remove them from your changes before pushing:"
  echo "$BLOCKED"
  echo
  echo "Tip: these are usually generated/runtime files and should not be committed."
  exit 1
fi

echo "Pre-push checks passed."
exit 0
